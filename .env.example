# Groq as primary is strongly recommended — it's consistently fast (~2-5s).
# OpenRouter's free-tier model can take 7-16+ seconds per call and
# occasionally returns empty completions under load, which is what was
# causing tick timeouts. Keep OpenRouter as the fallback only.
LLM_PROVIDER=groq

GROQ_API_KEY=your_key_here
OPENROUTER_API_KEY=your_key_here

# Optional: cap simultaneous outbound LLM calls (default 5). Lower this if
# you're on a stricter free-tier rate limit; raise it if your plan allows more.
LLM_CONCURRENCY_LIMIT=5
